# Growth Engine configuration for the local go-to-market skill

# Core settings
GROWTH_ENGINE_DATA_DIR=./skills/go-to-market/data/experiments
GROWTH_ENGINE_AGENTS=content,email,linkedin,seo,blog
HIGH_VOLUME_AGENTS=content,email
LOW_VOLUME_AGENTS=seo,linkedin,blog

# Statistical thresholds
P_WINNER=0.05
P_TREND=0.10
LIFT_WIN=15.0
BOOTSTRAP_ITERATIONS=1000
BATCH_MODE_MAX_VARIANTS=10

# Optional pacing targets
DAILY_LEAD_TARGET=10
WEEKLY_CANDIDATE_TARGET=400

# Optional external API checks for pacing-alert.py
PIPELINE_API_URL=
PIPELINE_AUTH_TOKEN=
RECRUITING_API_URL=
RECRUITING_AUTH_TOKEN=
EMAIL_API_URL=
EMAIL_AUTH_TOKEN=
OUTBOUND_CAMPAIGNS={}
RECRUITING_CAMPAIGNS={}

# Timezone used by pacing-alert.py for optional external data
TZ_OFFSET=0
TZ_LABEL=UTC
